# Copy this file to .env and fill in real values.
# Nothing here is a secret — it's a template.

# --- Database (Supabase Postgres) ---
# From Supabase dashboard → Project Settings → Database → Connection string.
# URL-encode any special characters in the password (e.g. "@" -> "%40").
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- Auth.js (NextAuth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# --- Cloudinary (product/content image uploads) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Supabase (auth) ---
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- M-Pesa Daraja (Safaricom) ---
# Get sandbox credentials at https://developer.safaricom.co.ke
# Until these are set, checkout still creates real orders — it just skips
# the STK push and tells the customer payments aren't live yet.
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
# Must be a publicly reachable HTTPS URL — Safaricom calls this to report
# whether the customer approved or cancelled the STK push.
MPESA_CALLBACK_URL="https://your-domain.com/api/payments/mpesa/callback"
# "sandbox" or "production"
MPESA_ENV="sandbox"
